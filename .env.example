# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# CSRF / NextAuth secret (generate: openssl rand -base64 32)
CSRF_SECRET="CHANGE_ME_TO_RANDOM_SECRET"
AUTH_SECRET="CHANGE_ME_TO_RANDOM_SECRET"
NEXT_PUBLIC_BASE_URL="https://your-app.vercel.app"

# Admin credentials (used by seed: npx prisma db seed)
ADMIN_EMAIL="admin@monivia.it"
ADMIN_PASSWORD="GENERATE_A_STRONG_PASSWORD"

# SMTP (optional — fallback if Resend not configured)
# SMTP_HOST="smtp.hostinger.com"
# SMTP_PORT="465"
# SMTP_USER="banca@monivia.it"
# SMTP_PASS=""

# Resend (recommended — free 100 emails/day)
# Get API key at https://resend.com/api-keys
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Monivia Banca <banca@monivia.it>"
