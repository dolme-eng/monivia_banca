# Database (Supabase PostgreSQL)
# Get your connection string from: https://supabase.com/dashboard → Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# CSRF / NextAuth secret (generate a random string: openssl rand -base64 32)
CSRF_SECRET="CHANGE_ME_TO_A_RANDOM_SECRET"
